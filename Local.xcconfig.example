// Copy this file to `Local.xcconfig` (which is gitignored) and set
// DEVELOPMENT_TEAM to your Apple Developer / personal team ID.
//
// To find your team ID:
//   1. Open Xcode → Settings → Accounts.
//   2. Select your Apple ID on the left.
//   3. The 10-character team ID is shown next to each team name.
//
// If you use a personal team (no paid Apple Developer account), set
// CODE_SIGN_IDENTITY to "Apple Development" and leave automatic
// signing enabled — Xcode will create a personal-team provisioning
// profile automatically.

DEVELOPMENT_TEAM = REPLACE_WITH_YOUR_TEAM_ID
CODE_SIGN_IDENTITY = Apple Development
CODE_SIGN_STYLE = Automatic
